# Copy this file to .env.local for machine-specific development settings.
# .env.local is intentionally git-ignored.

# Simulator server URL. The default works when the simulator and Mac server
# run on the same Mac.
PRIVATE_MOMENTS_SERVER_URL=http://127.0.0.1:3210

# Real-device install target. Use the iPhone name shown by:
# xcrun devicectl list devices
PRIVATE_MOMENTS_DEVICE_NAME="Your iPhone"

# Real-device server URL. This can be a LAN URL, a Tailscale/private-VPN URL,
# a Cloudflare Tunnel URL, or any HTTPS endpoint you protect yourself.
PRIVATE_MOMENTS_DEVICE_SERVER_URL=

# Optional bundled fallback URL. The app uses this only as an extra candidate
# when the user-configured Server URL is unavailable or route-missing.
PRIVATE_MOMENTS_FALLBACK_SERVER_URL=

# Optional App Store public links shown from Settings. Use stable HTTPS pages.
# scripts/write-ios-local-config.sh escapes URL values for Xcode .xcconfig files;
# keep normal https:// URLs here.
PRIVATE_MOMENTS_PRIVACY_POLICY_URL=
PRIVATE_MOMENTS_PRIVACY_POLICY_URL_ZH_HANS=
PRIVATE_MOMENTS_PRIVACY_POLICY_URL_EN=
PRIVATE_MOMENTS_SUPPORT_URL=

# iOS signing and identifiers. Keep these stable for your own installed app
# if you want iOS to preserve the existing app container and App Group data.
PRIVATE_MOMENTS_DEVELOPMENT_TEAM=
PRIVATE_MOMENTS_IOS_BUNDLE_ID=dev.privatemoments.app
PRIVATE_MOMENTS_IOS_SHARE_BUNDLE_ID=dev.privatemoments.app.share
PRIVATE_MOMENTS_IOS_TESTS_BUNDLE_ID=dev.privatemoments.app.tests
PRIVATE_MOMENTS_IOS_LIST_TESTS_BUNDLE_ID=dev.privatemoments.app.list-continuation-tests
PRIVATE_MOMENTS_IOS_APP_GROUP=group.dev.privatemoments.app
PRIVATE_MOMENTS_ICLOUD_CONTAINER_ID=iCloud.dev.privatemoments.app
PRIVATE_MOMENTS_ICLOUD_CONTAINER_ENVIRONMENT=Development
PRIVATE_MOMENTS_IOS_DISPLAY_NAME=Ownlight
PRIVATE_MOMENTS_IOS_SHARE_DISPLAY_NAME="Save to Ownlight"

# Optional isolated real-device UAT flavor. It installs next to the daily app
# and uses a separate app container, Keychain access group, and App Group.
PRIVATE_MOMENTS_UAT_IOS_BUNDLE_ID=dev.privatemoments.app.uat
PRIVATE_MOMENTS_UAT_IOS_SHARE_BUNDLE_ID=dev.privatemoments.app.uat.share
PRIVATE_MOMENTS_UAT_IOS_TESTS_BUNDLE_ID=dev.privatemoments.app.uat.tests
PRIVATE_MOMENTS_UAT_IOS_LIST_TESTS_BUNDLE_ID=dev.privatemoments.app.uat.list-continuation-tests
PRIVATE_MOMENTS_UAT_IOS_APP_GROUP=group.dev.privatemoments.app.uat
PRIVATE_MOMENTS_UAT_ICLOUD_CONTAINER_ID=iCloud.dev.privatemoments.app.uat
PRIVATE_MOMENTS_UAT_IOS_DISPLAY_NAME="Ownlight UAT"
PRIVATE_MOMENTS_UAT_IOS_SHARE_DISPLAY_NAME="Save to Ownlight UAT"
