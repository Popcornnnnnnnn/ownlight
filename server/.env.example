HOST=127.0.0.1
PORT=3210
LOG_LEVEL=info
PRIVATE_MOMENTS_INITIAL_PASSWORD=change-me-before-use

# For local development. Prisma resolves this path relative to server/prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Optional: use this to keep runtime test data out of the production macOS app data directory.
PRIVATE_MOMENTS_DATA_DIR="./data"

# Optional AI media summaries. The API key stays on the Mac server.
# AI_SUMMARY_PROVIDER=openai
# AI_SUMMARY_BASE_URL=https://api.openai.com/v1
# AI_SUMMARY_MODEL=gpt-4o-mini
# Optional fallback provider. The primary health URL is checked on startup and then
# periodically; when it is down, summary/review requests use the fallback until the
# primary probe recovers.
# AI_SUMMARY_PRIMARY_HEALTH_URL=http://127.0.0.1:3000/health
# AI_SUMMARY_PRIMARY_HEALTHY_INTERVAL_MS=60000
# AI_SUMMARY_PRIMARY_DOWN_INTERVAL_MS=15000
# AI_SUMMARY_PRIMARY_HEALTH_TIMEOUT_MS=1000
# AI_SUMMARY_PRIMARY_HEALTH_STALE_MS=120000
# AI_SUMMARY_FALLBACK_PROVIDER=deepseek
# AI_SUMMARY_FALLBACK_BASE_URL=https://api.deepseek.com
# AI_SUMMARY_FALLBACK_FAST_MODEL=deepseek-v4-flash
# AI_SUMMARY_FALLBACK_PRO_MODEL=deepseek-v4-pro
# AI_SUMMARY_FALLBACK_API_KEY=replace-with-fallback-provider-key
# AI_SUMMARY_LONG_CONTENT_THRESHOLD_CHARS=8000
# AI_TRANSCRIPTION_PROVIDER=local
# AI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# AI_LOCAL_TRANSCRIPTION_PYTHON=./.venv/bin/python
# AI_LOCAL_TRANSCRIPTION_SCRIPT=./scripts/local-transcribe.py
# AI_LOCAL_TRANSCRIPTION_MODEL=mlx-community/whisper-turbo
# AI_LOCAL_TRANSCRIPTION_TIMEOUT_MS=600000
# AI_SUMMARY_API_KEY=replace-with-provider-key
# AI_SUMMARY_TIMEOUT_MS=60000
